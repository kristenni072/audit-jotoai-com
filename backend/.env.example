# 通用Web后端环境变量配置示例

# --- 必需配置 ---

# 服务器端口
PORT=3001

# 运行环境 (development, production)
NODE_ENV=production

# JWT密钥 (用于生成和验证认证Token)
# 强烈建议使用以下命令生成一个强随机密钥
# openssl rand -base64 32
JWT_SECRET=

# --- SMTP邮件配置 (联系表单和邮件通知功能需要) ---

# SMTP服务器地址
SMTP_HOST=

# SMTP服务器端口 (通常为 587 或 465)
SMTP_PORT=587

# SMTP用户名 (通常是你的邮箱地址)
SMTP_USER=

# SMTP密码或授权码
SMTP_PASSWORD=

# 发件人邮箱地址 (必须和SMTP_USER是同一个域)
SMTP_FROM=

# --- 可选配置 ---

# -- LLM (大语言模型) 配置 (用于AI生成文章等功能) --

# LLM API密钥
LLM_API_KEY=

# LLM API端点
LLM_API_ENDPOINT=

# LLM 模型名称
LLM_MODEL=

# -- Unsplash (图片服务) 配置 (用于自动获取文章配图) --

# Unsplash API密钥
UNSPLASH_API_KEY=

# -- 飞书 (Lark) 集成配置 (用于发送通知到飞书群) --

# 飞书机器人Webhook地址
FEISHU_WEBHOOK=

# 飞书多维表格App ID (用于同步数据到表格)
FEISHU_APP_ID=

# 飞书多维表格App Secret
FEISHU_APP_SECRET=

# -- Redis配置 (推荐用于生产环境存储验证码) --

# REDIS_URL=redis://user:password@hostname:port
